# Banco de dados PostgreSQL
# Desenvolvimento local (ajuste user/host/porta conforme seu ambiente):
# DATABASE_URL="postgresql://usuario:senha@localhost:5432/erp_espaco_mulher?schema=public"
# Docker (conectar no container db na rede interna):
DATABASE_URL="postgresql://erp:erp_senha_segura@localhost:5433/erp_espaco_mulher?schema=public"

# JWT — obrigatório em produção. Use uma chave longa e aleatória.
# Exemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="sua-chave-secreta-aqui-mude-em-producao"

# Criação do usuário admin (usado por scripts como docker-init / criar-admin)
# ADMIN_EMAIL ou ADMIN_USERNAME é usado como login; ADMIN_PASSWORD como senha.
ADMIN_EMAIL="admin@erp.com"
ADMIN_PASSWORD="Admin@123456"

# Opcional: habilita rota de debug de conexão com o banco em produção (não recomendado)
# ENABLE_DB_DEBUG=1

# Ambiente (development | production)
# NODE_ENV=development
